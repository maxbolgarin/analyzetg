---
import '../styles/global.css';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const { title, description, path, ogImage, jsonLd, noindex } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <Head
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      jsonLd={jsonLd}
      noindex={noindex}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
