---
const points = [
  {
    title: 'Local-first',
    body: 'SQLite under <code>~/.unread/</code>. Messages, embeddings, analyses, secrets — all on your disk. The only network calls are to Telegram, your AI provider, and any URLs you point at.',
  },
  {
    title: 'Citations on every claim',
    body: 'Each bullet links back to a message, paragraph, or YouTube timestamp. Verify without re-opening the source. <code>--cite-context</code> expands the link into a <code>&lt;details&gt;</code> block with surrounding text.',
  },
  {
    title: 'Bring your own model',
    body: 'OpenAI, Anthropic, Gemini, OpenRouter, or local Ollama / LM Studio / vLLM. Switch with one command — caches and reports persist across switches.',
  },
  {
    title: 'Cost guardrails',
    body: '<code>--max-cost</code> aborts before overspend. <code>--dry-run</code> estimates without calling. <code>unread stats</code> shows lifetime spend by chat, preset, and day.',
  },
  {
    title: 'PII redaction',
    body: '<code>--redact</code> scrubs phones, emails, IBANs, and Luhn-valid card numbers from the API payload. Originals stay in your local DB and saved reports.',
  },
  {
    title: 'Source and report languages are independent',
    body: 'Russian chat → English digest. English file → Spanish summary. Hand-tuned preset structures ship for <code>en</code> and <code>ru</code>; other report languages still produce coherent reports.',
  },
];
---
<section class="props">
  <div class="container">
    <header class="head">
      <h2>Six things that matter on day 30 (not day 1).</h2>
      <p>The features that decide whether you still use this in a month.</p>
    </header>
    <ul class="list">
      {points.map((p) => (
        <li>
          <strong>{p.title}.</strong>
          <span set:html={` ${p.body}`} />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .props { padding: 4rem 0; border-top: 1px solid var(--border); }
  .head { max-width: 70ch; margin-bottom: 1.8rem; }
  .head h2 {
    font-size: clamp(1.7rem, 2.8vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.6rem;
  }
  .head p {
    color: var(--fg-muted);
    font-size: 1rem;
    margin: 0;
  }
  .list {
    margin: 0;
    padding: 0;
    list-style: none;
    max-width: 78ch;
    display: grid;
    gap: 0.9rem;
  }
  .list li {
    color: var(--fg-muted);
    font-size: 0.98rem;
    line-height: 1.65;
    padding-left: 1.1rem;
    position: relative;
  }
  .list li::before {
    content: "›";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .list strong { color: var(--fg); font-weight: 700; }
  .list code {
    background: var(--bg-code);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.1em 0.4em;
    font-size: 0.88em;
    color: var(--fg);
  }
</style>
