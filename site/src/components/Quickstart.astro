---
import { BASE } from '../consts';
import CodeBlock from './CodeBlock.astro';

const steps = [
  {
    label: '1. Install uv',
    note: 'one line, all platforms',
    cmd: 'curl -LsSf https://astral.sh/uv/install.sh | sh',
  },
  {
    label: '2. Install unread',
    cmd: 'uv tool install unread',
  },
  {
    label: '3. Set up',
    note: 'pick your AI provider, paste your key, optionally connect Telegram',
    cmd: 'unread init',
  },
  {
    label: '4. Run something',
    note: 'any URL, file path, or Telegram ref',
    cmd: 'unread "https://paulgraham.com/greatwork.html"',
  },
];
---
<section id="quickstart" class="quickstart">
  <div class="container">
    <header class="section-head">
      <h2>Install in four steps.</h2>
      <p class="sub">
        <code>uv</code> installs the binary in an isolated env. No virtualenv to activate, no <code>pip</code>
        conflicts, no global Python pollution. Works on macOS, Linux, and Windows.
      </p>
    </header>

    <ol class="steps">
      {steps.map((s) => (
        <li class="step">
          <div class="step-head">
            <span class="step-label">{s.label}</span>
            {s.note && <span class="step-note">{s.note}</span>}
          </div>
          <CodeBlock lang="bash" copyText={s.cmd}>{s.cmd}</CodeBlock>
        </li>
      ))}
    </ol>

    <p class="hint">
      Need more detail? See the <a href={`${BASE}/docs/install/`}>full install guide</a>.
    </p>
  </div>
</section>

<style>
  .quickstart { padding: 4rem 0; }
  .section-head { margin-bottom: 2rem; max-width: 62ch; }
  .section-head h2 {
    font-size: clamp(1.8rem, 3.2vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 0.6rem;
    font-weight: 700;
  }
  .section-head .sub {
    color: var(--fg-muted);
    font-size: 1.02rem;
    margin: 0;
  }
  .section-head .sub code, .hint code, .step-note code {
    background: var(--bg-code);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.1em 0.4em;
    font-size: 0.88em;
    color: var(--fg);
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .step { margin: 0; }
  .step-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }
  .step-label {
    color: var(--fg);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .step-note {
    color: var(--fg-muted);
    font-size: 0.85rem;
  }
  /* Tighten the CodeBlock margin inside a step */
  .step :global(.code-wrap) { margin: 0; }
  .hint {
    margin: 1.4rem 0 0;
    color: var(--fg-muted);
    font-size: 0.92rem;
  }
</style>
