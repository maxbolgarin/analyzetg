---
import { BASE, NAV } from '../consts';

const pathname = Astro.url.pathname.replace(/\/+$/, '/');
function isActive(href: string) {
  const norm = href.replace(/\/+$/, '/');
  if (norm === `${BASE}/`) return pathname === `${BASE}/` || pathname === BASE;
  return pathname === norm || pathname.startsWith(norm);
}
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={`${BASE}/`} aria-label="unread — home">
      <svg class="brand-mark" width="22" height="22" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M40 28 L28 28 L28 72 L40 72" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M60 28 L72 28 L72 72 L60 72" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="50" cy="50" r="8" fill="#3b82f6"/>
      </svg>
      <span class="brand-name">unread</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => {
        const external = /^https?:/i.test(item.href);
        return (
          <a
            href={item.href}
            class:list={["nav-link", { active: !external && isActive(item.href) }]}
            {...(external ? { rel: 'noopener', target: '_blank' } : {})}
          >
            {item.label}
            {external && (
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-left:.25rem;opacity:.6">
                <path d="M7 17L17 7M9 7h8v8"/>
              </svg>
            )}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--fg);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--fg); }
  .brand-mark { display: block; flex-shrink: 0; }
  .brand-name { font-family: var(--font-mono); }
  .nav {
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }
  .nav-link {
    color: var(--fg-muted);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
  }
  .nav-link:hover {
    color: var(--fg);
    background: var(--bg-elev);
  }
  .nav-link.active {
    color: var(--accent);
    background: var(--accent-soft);
  }
  @media (max-width: 640px) {
    .nav { gap: 0; }
    .nav-link { padding: 0.4rem 0.5rem; font-size: 0.85rem; }
  }
</style>
