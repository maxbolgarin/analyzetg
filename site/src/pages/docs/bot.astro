---
import DocsLayout from '../../layouts/DocsLayout.astro';
const mods = import.meta.glob('../../../../docs/bot.md', { eager: true });
const post = Object.values(mods)[0] as any;
const { Content, headings } = post;
---
<DocsLayout
  title="Telegram bot — self-hosted summarizer for forwarded messages, files, URLs · unread"
  description="Run unread as a self-hosted Telegram bot. Forward voice messages, PDFs, YouTube links, web pages, or t.me/ posts — get a Markdown summary back as a document."
  path="/docs/bot/"
  slug="bot"
  heading="Bot"
  headings={headings}
>
  <Content />
</DocsLayout>
