# Environment variables for docker-compose.bot.yml.
# Copy to .env.bot and fill in the placeholders before `docker compose up`.

# --- Telegram app credentials (my.telegram.org) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- AI provider (at least one) ---
# OpenAI is recommended for full feature coverage.
OPENAI_API_KEY=
# Optional alternatives:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=

# --- Bot (required) ---
# Token from @BotFather.
UNREAD_BOT_TOKEN=

# --- Bot (optional) ---
# Your numeric Telegram user ID. Required ONLY when you can't mount an
# authorized user session before starting the bot (e.g. you'll do the
# /upload_session flow after the bot is up). If you mount the session
# at /root/.unread/storage/session.sqlite before `up -d`, the bot
# derives owner_id from it automatically and ignores this env var.
# Find your ID by messaging https://t.me/userinfobot.
# UNREAD_BOT_OWNER_ID=
# Max concurrent analyses. 2 is plenty for a single user.
# UNREAD_BOT_CONCURRENCY=2
# Force every analyze to a specific preset (e.g. "summary", "detailed").
# UNREAD_BOT_DEFAULT_PRESET=
# Refuse files larger than this many MB up-front.
# UNREAD_BOT_MAX_FILE_MB=100
