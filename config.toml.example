# unread — configuration
#
# Convention: only settings you override are uncommented. Every other knob
# is listed commented-out, showing its default, so it's discoverable. Flip
# to uncomment and edit. Secrets (api_id / api_hash / api_key) live in .env.
#
# Model picks (Chat Completions API, refreshed 2026-05-01):
#   gpt-5.5       — newest flagship (1M ctx, $5/$30 per 1M); use for top-quality reduce.
#   gpt-5.4       — heavy reasoning ($2.50/$15); good cost/quality trade-off.
#   gpt-5.4-mini  — balance of cost/latency/quality for medium workloads ($0.75/$4.50).
#   gpt-5.4-nano  — cheapest; per-chunk map/filter passes ($0.20/$1.25).
#   gpt-4o / gpt-4o-mini — previous generation; gpt-4o-mini is the vision default.

# ====================================================== AI provider (chat)
#
# `provider` picks which adapter `analyze` / `ask` route through:
#   openai     — Chat Completions via the OpenAI SDK (default).
#   openrouter — Same SDK, pointed at https://openrouter.ai/api/v1.
#                Set `[openrouter] api_key` (or run `unread init`).
#   anthropic  — Claude (claude-sonnet-4-6 / claude-haiku-4-5 by default).
#                Set `[anthropic] api_key`.
#   google     — Gemini Developer API (gemini-2.5-flash / -lite by default).
#                Set `[google] api_key`.
#   local      — Self-hosted OpenAI-compatible server (Ollama / LM Studio
#                / vLLM). Set `[local] base_url` (default Ollama port).
#
# Capabilities other than chat (Whisper transcription, embeddings, vision)
# remain OpenAI-only and read `[openai] api_key` directly. They skip with
# a warning when that key is missing — you can still run the rest of the
# pipeline with a non-OpenAI chat provider.

# [ai]
# provider = "openai"
# base_url = ""             # OpenAI-compat endpoint override (Azure, …)
# chat_model = ""           # empty → provider's hard-coded default
# filter_model = ""

# [openrouter]
# api_key = "sk-or-…"
# base_url = "https://openrouter.ai/api/v1"

# [anthropic]
# api_key = "sk-ant-…"

# [google]
# api_key = "AI…"

# [local]
# base_url = "http://localhost:11434/v1"   # Ollama default
# api_key = "local-no-key"                  # most local servers ignore this

# ==================================================================== OpenAI

[openai]
# What you'll usually tune:
chat_model_default = "gpt-5.4-mini"
filter_model_default = "gpt-5.4-nano"

# Whisper transcription language. Empty = autodetect (good for mixed-language
# corpuses). Set to "ru" / "en" / "de" / … if every audio file is the same
# language — slightly faster + more accurate. Decoupled from [locale].language.
# audio_language = ""

# audio_model_default = "gpt-4o-mini-transcribe"
# temperature = 0.2
# request_timeout_sec = 120
# max_retries = 5

# ==================================================================== Locale
#
# Three independent language axes. See README.md "Language" for the full
# story; the short version:
#
#   * language        — UI / wizard / settings menu / banners. The CLI
#                       talks to the human in this language.
#   * report_language — what the LLM writes the analysis in. Picks the
#                       presets/<lang>/ directory (which is autonomous —
#                       no cross-language fallback). Empty = follow `language`.
#   * content_language — Whisper-style hint about the SOURCE content
#                       language. When set, one extra line is added to
#                       the system prompt telling the LLM to trust that
#                       the input is in this language. Empty (the default)
#                       means the LLM auto-detects from the source text.

# [locale]
# language = "en"           # "en", "ru" (other ISO codes work if you add
#                           # presets/<code>/ + i18n entries).
# report_language = ""      # Empty = follow `language`. Set to "ru" if
#                           # you want the LLM to write in Russian even
#                           # though your CLI / settings menu is English.
# content_language = ""     # Empty = AI auto-detects the source language
#                           # from the content. Set to "zh"/"ru"/… as a
#                           # Whisper-style override when the AI is
#                           # mis-detecting (e.g. analyzing Chinese
#                           # Wikipedia with a Russian report).

# ======================================================================== Ask

# [ask]
# Whole-doc-vs-retrieval cutoff for `unread ask <url|file>`.
# Below: send the full extracted text in one LLM call.
# Above: chunk + retrieve top-K (same path used for chat-archive ask).
# doc_full_text_cutoff_tokens = 32000

# Retrieval / rerank pipeline knobs (also applies to chat-archive ask):
# rerank_enabled = true
# rerank_top_k = 500        # candidate pool before rerank
# rerank_keep = 50          # what survives rerank → flagship model
# rerank_batch_size = 50    # messages per cheap-model call
# rerank_model = ""         # empty → falls back to filter_model

# =================================================================== Analyze

[analyze]
# Drop messages shorter than N chars after enrichment. 0 = keep everything
# (including media-only rows that didn't get enrichment text).
min_msg_chars = 3

# Collapse forwards/memes with identical text. false = keep every duplicate.
dedupe_forwards = true

# Cap on the final reduce output. Bump if "Output truncated" banners appear.
output_budget_tokens = 1500

# safety_margin_tokens = 4000          # context cushion; bump for non-English
# chunk_soft_break_minutes = 30        # roll new chunk on > N min idle gap
# map_concurrency = 4                  # parallel per-chunk OpenAI calls

# Scrub phone / email / IBAN / Luhn-valid card numbers from the prompt
# sent to the LLM. Originals stay in the local DB and the saved Markdown
# report — only the API payload is redacted. Off by default; flip on for
# a privacy-positive run, or pass `--redact` to override per-call.
# redact = false

# ==================================================================== Enrich
#
# Per-run overrides via CLI: --enrich=image,link / --enrich-all / --no-enrich.
# Uncomment below only for persistent defaults (what every run uses when no
# CLI flag is passed).

[enrich]
# Vision model for --enrich=image. gpt-4o-mini is cheap and decent for
# "screenshot of text / photo of product" descriptions.
vision_model = "gpt-4o-mini"

# Defaults (commented = config value matches default):
# voice = true
# videonote = true
# video = false
# image = false
# doc = false
# link = false   # opt-in: one OpenAI call per unique URL; enable per-run with --enrich=link

# Cost caps per run (skipped once exceeded — re-run to get more):
# max_images_per_run = 50
# max_link_fetches_per_run = 50
# max_doc_bytes = 25000000             # 25 MB hard download cap
# max_doc_chars = 20000                # text excerpt cap after extract
# link_fetch_timeout_sec = 10
# concurrency = 3                      # parallel enrichment API calls

# doc_model / link_model default to filter_model when unset.
# doc_model = "gpt-5.4-nano"
# link_model = "gpt-5.4-nano"

# Host substring match (case-insensitive) — URLs on these domains are skipped.
# skip_link_domains = ["twitter.com", "x.com"]

# ==================================================================== Pricing
#
# $ per 1M tokens (chat) / $ per minute (audio). `unread stats` uses these to
# attribute spend. A model missing from this table shows up as
# "⚠ N call(s) had no pricing entry" in the stats output.
# Keep entries for every model you actually use.
# Rates last refreshed 2026-05-01. `unread/ai/models.py` ships the same
# table for the model picker, so these entries here are advisory unless
# you want to override them.

# ----- OpenAI ($/1M tokens) -----
[pricing.chat."gpt-5.5"]
input = 5.00
cached_input = 0.50
output = 30.00

[pricing.chat."gpt-5.4"]
input = 2.50
cached_input = 0.25
output = 15.00

[pricing.chat."gpt-5.4-mini"]
input = 0.75
cached_input = 0.075
output = 4.50

[pricing.chat."gpt-5.4-nano"]
input = 0.20
cached_input = 0.02
output = 1.25

[pricing.chat."gpt-4o"]
input = 2.50
cached_input = 1.25
output = 10.00

[pricing.chat."gpt-4o-mini"]
input = 0.15
cached_input = 0.075
output = 0.60

[pricing.audio]
"gpt-4o-mini-transcribe" = 0.003
"gpt-4o-transcribe" = 0.006
# "whisper-1" = 0.006

# ----- Anthropic Claude — used when `ai.provider = "anthropic"`. -----
# `cached_input` reflects the cache-read rate (~0.1× input). Refresh
# from docs.claude.com/en/docs/about-claude/pricing when rates move.
[pricing.chat."claude-opus-4-7"]
input = 5.00
cached_input = 0.50
output = 25.00

[pricing.chat."claude-sonnet-4-6"]
input = 3.00
cached_input = 0.30
output = 15.00

[pricing.chat."claude-haiku-4-5"]
input = 1.00
cached_input = 0.10
output = 5.00

# ----- Google Gemini — used when `ai.provider = "google"`. -----
# Pricing for prompts ≤200k tokens. Refresh from ai.google.dev/pricing.
[pricing.chat."gemini-3.1-pro-preview"]
input = 2.00
cached_input = 0.50
output = 12.00

[pricing.chat."gemini-3.1-flash-lite-preview"]
input = 0.25
cached_input = 0.0625
output = 1.50

[pricing.chat."gemini-2.5-pro"]
input = 1.25
cached_input = 0.31
output = 10.00

[pricing.chat."gemini-2.5-flash"]
input = 0.30
cached_input = 0.075
output = 2.50

[pricing.chat."gemini-2.5-flash-lite"]
input = 0.10
cached_input = 0.025
output = 0.40

# OpenRouter aliases (`ai.provider = "openrouter"`). Pricing varies by
# upstream model; the alias keys mirror the SDK's vendor/model form.
# Add entries for the models you actually use; missing models surface
# as "unpriced calls" in `unread stats`.
# [pricing.chat."openai/gpt-5.4-mini"]
# input = 0.75
# cached_input = 0.075
# output = 4.50

# ==================================================================== Media

# [media]
# transcribe_voice = true
# transcribe_videonote = true
# transcribe_video = false             # audio track of videos — opt-in (spendy)
# max_media_duration_sec = 600         # skip voices/videos longer than this
# min_media_duration_sec = 1
# download_concurrency = 3
# tmp_dir = "storage/media"
# ffmpeg_path = "ffmpeg"

# =================================================================== Telegram

# [telegram]
# session_path = "storage/session.sqlite"
# max_msgs_per_minute = 3000

# ======================================================================= Sync

# [sync]
# default_lookback_days = 7
# batch_size = 500
# concurrency = 3

# ================================================================== Retention

# [retention]
# message_retention_days = 0           # 0 = forever
# keep_transcripts_forever = true
# keep_analysis_cache_forever = true

# ==================================================================== Storage

# [storage]
# data_path = "storage/data.sqlite"

# ==================================================================== Logging

# [logging]
# Path to a file where structured logs are appended for production
# debugging (rotated). Empty / omitted = terminal-only.
# file_path = "~/.unread/storage/unread.log"
# file_max_bytes = 10000000  # 10 MB before rotation
# file_backup_count = 3
