# analyzetg — configuration
# Copy to config.toml and adjust values. Most values have sane defaults;
# only overrides need to be present.

[telegram]
# api_id / api_hash are read from .env (TELEGRAM_API_ID / TELEGRAM_API_HASH).
session_path = "storage/session.sqlite"
max_msgs_per_minute = 3000

[openai]
# api_key is read from .env (OPENAI_API_KEY).
#
# Model picks (Chat Completions API — same stack this project uses):
#   gpt-5.4          — flagship: long context, strong reasoning; use for final summaries.
#   gpt-5.4-mini     — balance of cost/latency/quality for medium workloads.
#   gpt-5.4-nano     — cheapest; good for high-volume per-chunk “map” / filter passes.
#   gpt-4o / gpt-4o-mini — still available if you prefer the previous generation.
# Reasoning-only models (o3, o4-mini, …) are a different tradeoff; not required here.
#
chat_model_default = "gpt-5.4"
filter_model_default = "gpt-5.4-nano"
audio_model_default = "gpt-4o-mini-transcribe"
audio_language = "ru"
request_timeout_sec = 120
max_retries = 5
temperature = 0.2

[sync]
default_lookback_days = 7
batch_size = 500
concurrency = 3

[media]
transcribe_voice = true
transcribe_videonote = true
transcribe_video = false
max_media_duration_sec = 600
min_media_duration_sec = 1
download_concurrency = 3
tmp_dir = "storage/media"
ffmpeg_path = "ffmpeg"

[analyze]
min_msg_chars = 3
output_budget_tokens = 1500
# Cushion between packed-chunk size and the model's hard context cap.
# Tiktoken undercounts Cyrillic and some emoji; 4000 absorbs that gap.
# Bump higher if you ever hit context_length_exceeded on non-English chats.
safety_margin_tokens = 4000
chunk_soft_break_minutes = 30
dedupe_forwards = true
map_concurrency = 4

[retention]
message_retention_days = 0            # 0 = forever
keep_transcripts_forever = true
keep_analysis_cache_forever = true

[storage]
data_path = "storage/data.sqlite"

# Pricing tables — update manually when OpenAI publishes new rates (platform.openai.com/docs/pricing).
# Chat: $ per 1M tokens (standard tier: input, cached input, output).
[pricing.chat."gpt-5.4"]
input = 2.50
cached_input = 0.25
output = 15.00

[pricing.chat."gpt-5.4-mini"]
input = 0.75
cached_input = 0.075
output = 4.50

[pricing.chat."gpt-5.4-nano"]
input = 0.20
cached_input = 0.02
output = 1.25

[pricing.chat."gpt-4o"]
input = 2.50
cached_input = 1.25
output = 10.00

[pricing.chat."gpt-4o-mini"]
input = 0.15
cached_input = 0.075
output = 0.60

[pricing.chat."gpt-5"]
input = 1.25
cached_input = 0.125
output = 10.00

[pricing.chat."o3-mini"]
input = 1.10
cached_input = 0.55
output = 4.40

# Audio: $ per minute.
[pricing.audio]
"whisper-1" = 0.006
"gpt-4o-transcribe" = 0.006
"gpt-4o-mini-transcribe" = 0.003
